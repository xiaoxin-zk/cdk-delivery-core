{
  "name": "cdk-delivery-core",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "setup": "node scripts/setup-env.js",
    "postinstall": "node scripts/setup-env.js",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "bootstrap:prod": "tsx scripts/bootstrap-production.ts",
    "docker:start": "npm run bootstrap:prod && next start"
  },
  "dependencies": {
    "@prisma/client": "5.22.0",
    "bcryptjs": "2.4.3",
    "clsx": "2.1.1",
    "date-fns": "4.1.0",
    "ioredis": "5.4.1",
    "jsonwebtoken": "9.0.2",
    "lucide-react": "0.468.0",
    "next": "14.2.16",
    "nodemailer": "6.9.16",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "2.4.6",
    "@types/jsonwebtoken": "9.0.7",
    "@types/node": "22.10.2",
    "@types/nodemailer": "6.4.17",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "autoprefixer": "10.4.20",
    "eslint": "8.57.1",
    "eslint-config-next": "14.2.16",
    "esbuild": "0.23.1",
    "postcss": "8.4.49",
    "prettier": "3.4.2",
    "prisma": "5.22.0",
    "tailwindcss": "3.4.17",
    "tsx": "4.19.2",
    "typescript": "5.7.2",
    "vitest": "2.1.8"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
