# Application
APP_PORT=3000
APP_URL=http://localhost:3000

# Database / cache used by docker-compose service names.
# Replace POSTGRES_PASSWORD first, then keep DATABASE_URL in sync.
POSTGRES_DB=cdk_delivery_core
POSTGRES_USER=cdk
POSTGRES_PASSWORD=change-this-to-a-strong-random-password
DATABASE_URL=postgresql://cdk:change-this-to-a-strong-random-password@postgres:5432/cdk_delivery_core?schema=public
REDIS_URL=redis://redis:6379

# Required production secrets. Use independent random values with at least 32 characters.
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-chars
APP_SECRET=replace-with-another-long-random-secret-at-least-32-chars

# Optional first admin bootstrap. Change the password before first production start.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-a-strong-admin-password

# SMTP can also be configured in the admin UI. Password is stored encrypted by APP_SECRET.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_NAME=CDK Delivery Core
SMTP_FROM_EMAIL=no-reply@example.com
SMTP_SECURE=false

# Cloudflare Turnstile can also be configured in the admin UI. Secret key is stored encrypted by APP_SECRET.
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
